# --- Supabase ---
# Get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (direct Postgres) ---
# Not used by the app (which goes through supabase-js), but useful if you
# want to run psql / migrations / scripts against the DB directly.
# Pooled connection for runtime queries (port 6543):
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for migrations (port 5432):
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Amazon affiliate ---
# Your Amazon Associates tracking tag, e.g. officehoursg-20
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=
# Default Amazon TLD (com, ca, co.uk, ...)
NEXT_PUBLIC_AMAZON_TLD=com

# --- Site ---
# Canonical production URL. Used as a fallback when Origin header is
# unavailable (rare). In Vercel, leave unset in Preview env so previews
# use their own origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Vercel AI Gateway ---
# Used by /api/ai/gear-enrich to auto-populate gear fields from a short
# description. Generate at https://vercel.com/dashboard → AI → API Keys.
# On Vercel deployments with the AI Gateway integration enabled, this is
# auto-injected and you don't need to set it here. For local dev, either:
#   (a) `vercel env pull` to fetch it, or
#   (b) Generate a personal key and paste here.
AI_GATEWAY_API_KEY=
